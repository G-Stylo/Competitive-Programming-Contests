#include <bits/stdc++.h>
using namespace std;
 
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int t;
    cin >> t;
    for (int i = 0; i < t; ++i) {
        int n, x, y;
        cin >> n >> x >> y;
        int g = gcd(x, y);
        bool possible = true;
        for (int j = 1; j <= n; ++j) {
            int p;
            cin >> p;
            if (p % g != j % g) {
                possible = false;
            }
        }
        if (possible) {
            cout << "YES" << '\n';
        } else {
            cout << "NO" << '\n';
        }
    }
    return 0;
}
