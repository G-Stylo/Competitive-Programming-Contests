#include <bits/stdc++.h>
using namespace std;
 
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
 
    int t;
    cin >> t;
    for (int i = 0; i < t; ++i) {
        int n;
        cin >> n;
        long long prefix_sum = 0;
        bool possible = true;
        
        for (int j = 1; j <= n; ++j) {
            long long a;
            cin >> a;
            prefix_sum += a;
            long long required_sum = (long long)j * (j + 1) / 2;
            
            if (prefix_sum < required_sum) {
                possible = false;
            }
        }
        
        if (possible) {
            cout << "YES" << '\n';
        } else {
            cout << "NO" << '\n';
        }
    }
    return 0;
}
