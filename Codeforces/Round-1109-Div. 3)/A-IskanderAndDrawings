#include <bits/stdc++.h>
using namespace std;
 
int main() {
    int t;
    cin >> t;
    for (int i = 0; i < t; ++i) {
        int n;
        cin >> n;
        string s;
        cin >> s;
        
        int max_time = 0;
        int current_len = 0;
        
        for (int j = 0; j < n; ++j) {
            if (s[j] == '#') {
                current_len++;
            } else {
                if (current_len > 0) {
                    max_time = max(max_time, (current_len + 1) / 2);
                    current_len = 0;
                }
            }
        }
        
        if (current_len > 0) {
            max_time = max(max_time, (current_len + 1) / 2);
        }
        
        cout << max_time << '\n';
    }
    return 0;
}
