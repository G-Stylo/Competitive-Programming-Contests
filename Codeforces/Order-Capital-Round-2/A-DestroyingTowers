/* 
    Difficulty: 800
*/

#include <iostream>
#include <vector>
#include <algorithm>
 
using namespace std;
 
void solve() {
    int n;
    if (!(cin >> n)) return;
    
    vector<int> a(n);
    for (int i = 0; i < n; ++i) {
        cin >> a[i];
    }
 
    long long total_sum = 0;
    int current_min = a[0];
 
    for (int i = 0; i < n; ++i) {
        current_min = min(current_min, a[i]);
        total_sum += current_min;
    }
 
    cout << total_sum << "\n";
}
 
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
 
    int t;
    if (!(cin >> t)) return 0;
    while (t--) {
        solve();
    }
    return 0;
}
