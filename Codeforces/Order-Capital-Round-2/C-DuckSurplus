#include <bits/stdc++.h>
 
using namespace std;
 
void solve() {
    int n;
    if (!(cin >> n)) return;
    
    vector<long long> a(n);
    for (int i = 0; i < n; ++i) {
        cin >> a[i];
    }
 
    if (n == 0) {
        cout << 0 << "\n";
        return;
    }
 
    long long current_last_pile = a[0];
 
    for (int i = 1; i < n; ++i) {
        if (a[i] < current_last_pile) {
            current_last_pile += a[i];
        } else {
          
            current_last_pile = a[i];
        }
    }
 
    cout << current_last_pile << "\n";
}
 
int main() {
 
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
 
    int t;
    if (!(cin >> t)) return 0;
    while (t--) {
        solve();
    }
    return 0;
}
